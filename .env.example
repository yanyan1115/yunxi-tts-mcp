# Copy this file to .env or export these variables in your shell.
# Do not commit real tokens, chat IDs, secrets, domains, or server paths.

# Output files
TTS_OUTPUT_DIR=/opt/yunxi-tts-mcp/output
TTS_PUBLIC_BASE_URL=https://example.com

# Telegram sendVoice support
TTS_TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN
TTS_TELEGRAM_BOT_TOKEN_ENV=TTS_TELEGRAM_BOT_TOKEN

# Streamable HTTP MCP
MCP_HOST=127.0.0.1
MCP_PORT=8891
MCP_ALLOWED_HOSTS=example.com,example.com:*
MCP_ALLOWED_ORIGINS=https://example.com

# OAuth for remote MCP connectors
MCP_OAUTH_ENABLED=1
MCP_OAUTH_CONNECT_SECRET=YOUR_CONNECT_SECRET
MCP_OAUTH_ISSUER_URL=https://example.com
MCP_OAUTH_RESOURCE_URL=https://example.com/mcp
MCP_OAUTH_STORE=/opt/yunxi-tts-mcp/oauth_store.json
